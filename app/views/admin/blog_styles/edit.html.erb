<% content_for(:admin_title) { "전략 수정: #{@blog_style.source_name}" } %>

<div style="max-width: 720px;">
  <div style="margin-bottom: 1.5rem;">
    <a href="<%= admin_blog_style_path(@blog_style) %>" class="admin-btn">← 상세로 돌아가기</a>
  </div>

  <%= form_with(model: [:admin, @blog_style], local: true) do |f| %>
    <div style="background: #ffffff; border: 0.5px solid #E5E3DC; border-radius: 20px; padding: 1.5rem; margin-bottom: 1.5rem;">
      <h3 style="font-size: 15px; font-weight: 600; letter-spacing: -0.01em; margin: 0 0 1rem;">기본 정보</h3>

      <div class="admin-form-group">
        <%= f.label :source_name, "출처 이름" %>
        <%= f.text_field :source_name %>
      </div>

      <div class="admin-form-group">
        <%= f.label :raw_script, "스크립트 / 참고 자료" %>
        <%= f.text_area :raw_script, rows: 10 %>
      </div>

      <div class="admin-form-group">
        <%= f.label :notes, "메모" %>
        <%= f.text_area :notes, rows: 3 %>
      </div>
    </div>

    <div style="background: #ffffff; border: 0.5px solid #E5E3DC; border-radius: 20px; padding: 1.5rem; margin-bottom: 1.5rem;">
      <h3 style="font-size: 15px; font-weight: 600; letter-spacing: -0.01em; margin: 0 0 1rem;">분석 결과</h3>

      <div class="admin-form-group">
        <%= f.label :hooking_patterns, "후킹 패턴 (JSON)" %>
        <%= f.text_area :hooking_patterns, rows: 8 %>
      </div>

      <div class="admin-form-group">
        <%= f.label :sentence_structure, "문장 구조 (JSON)" %>
        <%= f.text_area :sentence_structure, rows: 6 %>
      </div>

      <div class="admin-form-group">
        <%= f.label :psychological_triggers, "심리 트리거 (JSON)" %>
        <%= f.text_area :psychological_triggers, rows: 8 %>
      </div>

      <div class="admin-form-group">
        <%= f.label :tone_style, "톤/스타일 (JSON)" %>
        <%= f.text_area :tone_style, rows: 6 %>
      </div>
    </div>

    <div style="display: flex; gap: 0.75rem;">
      <%= f.submit "저장", class: "admin-btn admin-btn-primary" %>
      <a href="<%= admin_blog_style_path(@blog_style) %>" class="admin-btn">취소</a>
    </div>
  <% end %>
</div>
