<div class="admin-form">
  <%= form_with model: [:admin, banner], local: true do |f| %>
    <% if banner.errors.any? %>
      <div class="admin-flash admin-flash-alert">
        <strong><%= banner.errors.count %> error(s):</strong>
        <ul style="margin:0.5rem 0 0 1rem;">
          <% banner.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <h3 style="margin-bottom:1rem;font-size:1rem;">Title & Description</h3>

    <div class="admin-form-row">
      <div class="admin-form-group">
        <label>Title (English) *</label>
        <%= f.text_field :title_en %>
      </div>
      <div class="admin-form-group">
        <label>Title (Korean)</label>
        <%= f.text_field :title_ko %>
      </div>
    </div>

    <div class="admin-form-row">
      <div class="admin-form-group">
        <label>Description (English)</label>
        <%= f.text_field :description_en %>
      </div>
      <div class="admin-form-group">
        <label>Description (Korean)</label>
        <%= f.text_field :description_ko %>
      </div>
    </div>

    <h3 style="margin:1.5rem 0 1rem;font-size:1rem;">Link & Button</h3>

    <div class="admin-form-group">
      <label>Link URL</label>
      <%= f.text_field :link_url, placeholder: "https://example.com" %>
    </div>

    <div class="admin-form-row">
      <div class="admin-form-group">
        <label>Button Text (English)</label>
        <%= f.text_field :button_text_en %>
      </div>
      <div class="admin-form-group">
        <label>Button Text (Korean)</label>
        <%= f.text_field :button_text_ko %>
      </div>
    </div>

    <div class="admin-form-group">
      <label>Image URL (optional)</label>
      <%= f.text_field :image_url, placeholder: "https://example.com/image.png" %>
    </div>

    <h3 style="margin:1.5rem 0 1rem;font-size:1rem;">Placement</h3>

    <div class="admin-form-row">
      <div class="admin-form-group">
        <label>Page</label>
        <%= f.select :page, Banner::PAGES.map { |p| [p.capitalize, p] } %>
      </div>
      <div class="admin-form-group">
        <label>Position</label>
        <%= f.select :position, Banner::POSITIONS.map { |p| [p.titleize, p] } %>
      </div>
    </div>

    <div class="admin-form-row">
      <div class="admin-form-group">
        <label>Banner Type</label>
        <%= f.select :banner_type, Banner::BANNER_TYPES.map { |t| [t.capitalize, t] } %>
      </div>
      <div class="admin-form-group">
        <label>AdSense Slot ID</label>
        <%= f.text_field :adsense_slot_id, placeholder: "ca-pub-xxx / slot-xxx" %>
        <div class="admin-form-hint">Only for adsense type</div>
      </div>
    </div>

    <div class="admin-form-group">
      <label>
        <%= f.check_box :active %> Active
      </label>
    </div>

    <div style="display:flex;gap:0.75rem;margin-top:1.5rem;">
      <%= f.submit banner.persisted? ? "Update Banner" : "Create Banner", class: "admin-btn admin-btn-primary" %>
      <%= link_to "Cancel", admin_banners_path, class: "admin-btn" %>
    </div>
  <% end %>

  <% if banner.title_en.present? %>
    <div class="admin-preview">
      <h4>Preview</h4>
      <div class="banner-card">
        <div class="banner-content">
          <div class="banner-title"><%= banner.title_en %></div>
          <div class="banner-desc"><%= banner.description_en %></div>
        </div>
        <% if banner.link_url.present? %>
          <span class="banner-btn"><%= banner.button_text_en.presence || "Learn More" %></span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
