<% color_cycle = %w[teal gold purple] %>
<div class="banners-section">
  <% banners.each_with_index do |banner, i| %>
    <% if banner.banner_type == "adsense" && banner.adsense_slot_id.present? %>
      <div class="banner-adsense">
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="<%= banner.adsense_slot_id.split('/').first %>"
             data-ad-slot="<%= banner.adsense_slot_id.split('/').last %>"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
      </div>
    <% else %>
      <% color = color_cycle[i % 3] %>
      <a href="<%= banner.link_url %>" class="banner-card banner-card--<%= color %>" target="_blank" rel="noopener">
        <div class="banner-icon-box">
          <% case color
             when "teal" then %>🎓<%
             when "gold" then %>🌏<%
             when "purple" then %>🔗<%
             end %>
        </div>
        <div class="banner-content">
          <div class="banner-title"><%= banner.title %></div>
          <% if banner.description.present? %>
            <div class="banner-desc"><%= banner.description %></div>
          <% end %>
        </div>
        <% if banner.link_url.present? %>
          <span class="banner-btn"><%= banner.button_text %></span>
        <% end %>
      </a>
    <% end %>
  <% end %>
</div>
