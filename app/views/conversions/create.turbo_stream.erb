<%= turbo_stream.update "conversion_result" do %>
  <div class="result-card">
    <div class="result-status status-<%= @conversion.status %>">
      <strong><%= t("result.status") %>:</strong> <%= @conversion.status.capitalize %>
    </div>

    <% if @conversion.original_size.present? && @conversion.result_size.present? %>
      <div class="size-comparison">
        <span><%= t("result.original") %>: <%= number_to_human_size(@conversion.original_size) %></span>
        <span>&rarr;</span>
        <span><%= t("result.result") %>: <%= number_to_human_size(@conversion.result_size) %></span>
        <% reduction = (100.0 * (1 - @conversion.result_size.to_f / @conversion.original_size)).round(1) %>
        <span>(<%= reduction %>% <%= t("result.reduced") %>)</span>
      </div>
    <% end %>

    <% if @conversion.status == "done" && @conversion.result_file.attached? %>
      <a href="<%= download_conversion_path(@conversion) %>"
         class="btn btn-primary"
         data-turbo="false"><%= t("result.download") %></a>
    <% elsif @conversion.status == "failed" %>
      <p class="error-message"><%= t("result.failed_short") %></p>
    <% end %>
  </div>
<% end %>
