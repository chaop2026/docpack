<% content_for(:title, t("compress.title")) %>
<% page_meta(title: t("compress.title"), description: t("seo.compress_description"), path: "/compress") %>

<div class="container" data-controller="progress">
  <%= link_to root_path, class: "btn-back" do %>&larr; <%= t("nav.back") %><% end %>

  <div class="page-header">
    <div class="page-header-icon" style="background:var(--compress-light);color:var(--compress);">🗜</div>
    <div>
      <h1><%= t("compress.heading") %></h1>
      <p style="margin:0;"><%= t("compress.description") %></p>
    </div>
  </div>

  <%= form_with url: conversions_path, method: :post, data: { progress_target: "form" } do |f| %>
    <%= f.hidden_field :conversion_type, value: "compress" %>

    <div class="upload-zone upload-zone--compress" id="upload-zone" data-controller="upload">
      <p><%= t("compress.drop_zone") %></p>
      <%= f.file_field :files, multiple: true, accept: "image/jpeg,image/png,image/heic,image/webp",
          data: { upload_target: "input", action: "change->upload#preview", progress_target: "fileInput" } %>
      <p class="upload-hint"><%= t("upload.hint") %></p>
    </div>

    <div id="preview-area" data-upload-target="preview"></div>

    <div class="quality-slider" data-controller="quality-slider">
      <label class="quality-slider-label"><%= t("compress.slider_label") %></label>
      <div class="quality-slider-row">
        <span class="quality-slider-min"><%= t("compress.slider_min") %></span>
        <input type="range" name="target_percent" min="5" max="50" value="10" step="5"
               class="quality-slider-input"
               data-quality-slider-target="slider"
               data-action="input->quality-slider#update">
        <span class="quality-slider-max"><%= t("compress.slider_max") %></span>
      </div>
      <div class="quality-slider-value">
        <span><%= t("compress.slider_target") %></span>
        <strong data-quality-slider-target="display">10</strong><span>%</span>
        <span class="quality-slider-hint" data-quality-slider-target="hint"></span>
      </div>
      <p class="quality-slider-desc"><%= t("compress.slider_desc") %></p>
    </div>

    <div class="progress-area" data-progress-target="progressArea">
      <div class="progress-track">
        <div class="progress-bar progress-bar--compress" data-progress-target="progressBar"></div>
      </div>
      <div class="progress-text" data-progress-target="progressText"><%= t("compress.uploading") %></div>
    </div>

    <div class="processing-area" data-progress-target="processingArea">
      <div class="spinner spinner--compress"></div>
      <span class="processing-text"><%= t("compress.processing") %></span>
    </div>

    <%= f.submit t("compress.submit"), class: "btn btn--compress", data: { progress_target: "submitBtn" } %>
  <% end %>

  <turbo-frame id="conversion_result"></turbo-frame>

  <%= render_banners(page: "compress", position: "after_result") %>
</div>
