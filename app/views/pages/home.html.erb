<% content_for(:title, t("home.title")) %>
<% page_meta(title: t("home.title"), description: t("seo.home_description"), path: "/") %>

<div class="container">
  <header class="hero">
    <h1><%= t("home.heading") %></h1>
    <p><%= t("home.description") %></p>
  </header>

  <nav class="feature-nav">
    <%= link_to compress_path, class: "feature-card feature-card--compress" do %>
      <div class="feature-card-icon">🗜</div>
      <span class="feature-card-tag">IMAGE</span>
      <div class="feature-card-title"><%= t("home.compress") %></div>
      <p class="feature-card-desc"><%= t("compress.description") %></p>
      <span class="feature-card-btn"><%= t("compress.submit") %></span>
    <% end %>

    <%= link_to pdf_path, class: "feature-card feature-card--pdf" do %>
      <div class="feature-card-icon">📄</div>
      <span class="feature-card-tag">PDF</span>
      <div class="feature-card-title"><%= t("home.pdf") %></div>
      <p class="feature-card-desc"><%= t("pdf.description") %></p>
      <span class="feature-card-btn"><%= t("pdf.submit") %></span>
    <% end %>

    <%= link_to social_path, class: "feature-card feature-card--social" do %>
      <div class="feature-card-icon">📱</div>
      <span class="feature-card-tag">SOCIAL</span>
      <div class="feature-card-title"><%= t("home.social") %></div>
      <p class="feature-card-desc"><%= t("social.description") %></p>
      <span class="feature-card-btn"><%= t("social.submit") %></span>
    <% end %>
  </nav>

  <%= render_banners(page: "all", position: "after_result") %>
</div>
