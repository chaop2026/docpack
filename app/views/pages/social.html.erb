<% content_for(:title, t("social.title")) %>

<div class="container" data-controller="progress">
  <%= link_to root_path, class: "btn-back" do %>&larr; <%= t("nav.back") %><% end %>

  <div class="page-header">
    <div class="page-header-icon" style="background:var(--social-light);color:var(--social);">📱</div>
    <div>
      <h1><%= t("social.heading") %></h1>
      <p style="margin:0;"><%= t("social.description") %></p>
    </div>
  </div>

  <%= form_with url: conversions_path, method: :post, data: { progress_target: "form" } do |f| %>
    <%= f.hidden_field :conversion_type, value: "social" %>

    <div class="preset-options">
      <% SocialResizer::PRESETS.each do |key, preset| %>
        <label class="preset-option">
          <%= f.radio_button :preset, key, checked: key == "instagram_square" %>
          <span><%= preset[:label] %> (<%= preset[:width] %>&times;<%= preset[:height] %>)</span>
        </label>
      <% end %>
    </div>

    <div class="upload-zone upload-zone--social" id="upload-zone" data-controller="upload">
      <p><%= t("social.drop_zone") %></p>
      <%= f.file_field :files, multiple: true, accept: "image/jpeg,image/png,image/heic,image/webp",
          data: { upload_target: "input", action: "change->upload#preview", progress_target: "fileInput" } %>
    </div>

    <div id="preview-area" data-upload-target="preview"></div>

    <div class="progress-area" data-progress-target="progressArea">
      <div class="progress-track">
        <div class="progress-bar progress-bar--social" data-progress-target="progressBar"></div>
      </div>
      <div class="progress-text" data-progress-target="progressText"><%= t("social.uploading") %></div>
    </div>

    <div class="processing-area" data-progress-target="processingArea">
      <div class="spinner spinner--social"></div>
      <span class="processing-text"><%= t("social.processing") %></span>
    </div>

    <%= f.submit t("social.submit"), class: "btn btn--social", data: { progress_target: "submitBtn" } %>
  <% end %>

  <turbo-frame id="conversion_result"></turbo-frame>

  <%= render_banners(page: "social", position: "after_result") %>
</div>
