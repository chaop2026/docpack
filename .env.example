# Copy to .env and fill in values. Never commit .env.

PORT=3001

# Local development database (docker-compose)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Kamal deployment
KAMAL_REGISTRY_PASSWORD=

# Gmail SMTP (blog publish notifications)
GMAIL_USERNAME=
GMAIL_PASSWORD=

# Anthropic API (SafeFile AI scan + blog generator)
ANTHROPIC_API_KEY=
